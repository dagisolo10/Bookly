{
    "name": "backend",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --env-file=.env.local --watch src/index.ts",
        "start": "bun --env-file=.env.production run src/index.ts",
        "db:push:local": "bun --env-file=.env.local x prisma db push",
        "db:migrate:local": "bun --env-file=.env.local x prisma migrate dev",
        "db:studio:local": "bun --env-file=.env.local x prisma studio",
        "studio": "bunx prisma studio",
        "sync": "bun --env-file=.env.local x prisma db push && bun --env-file=.env.local x prisma generate",
        "reset": "bun --env-file=.env.local x prisma db push --force-reset && bun --env-file=.env.local x prisma generate",
        "seed": "bun --env-file=.env.local run src/prisma/seed.ts"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.8.0",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0",
        "supabase": "^2.102.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@clerk/express": "^2.1.17",
        "@ngneat/falso": "^8.0.2",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@supabase/supabase-js": "^2.106.2",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "multer": "^2.1.1",
        "pg": "^8.20.0",
        "socket.io": "^4.8.3",
        "zod": "^4.4.3"
    }
}
