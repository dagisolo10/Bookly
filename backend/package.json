{
    "name": "backend",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "start": "bun run src/index.ts",
        "sync": "bunx prisma db push && bunx prisma generate",
        "reset": "bunx prisma db push --force-reset && bunx prisma generate",
        "s": "bunx prisma studio",
        "seed": "bun run src/prisma/seed.ts"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.8.0",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@clerk/express": "^2.1.17",
        "@ngneat/falso": "^8.0.2",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "pg": "^8.20.0",
        "socket.io": "^4.8.3",
        "zod": "^4.4.3"
    }
}
